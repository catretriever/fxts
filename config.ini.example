# FXTS configuration — copy to config.ini and fill in your values.
# config.ini is listed in .gitignore and must never be committed.
#
# Each setting can also be overridden by an environment variable:
#   FXDB_HOST, FXDB_USER, FXDB_PASSWD, FXDB_NAME
#   FXTS_PORTFOLIO, FXTS_PRICE_ELEMENTS

[database]
# MariaDB connection details
host   = localhost
user   = fxts
passwd = changeme
db     = FXDB

[portfolio]
# Name must match a Portfolio value in MAP_Pfo_TEngine
name = FX Portfolio 1

[fxcross]
# Number of hourly bars to load per instrument at startup
price_elements = 2000
